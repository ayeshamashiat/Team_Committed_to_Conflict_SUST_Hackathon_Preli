# QueueStorm Investigator environment variables
# Copy this file to .env and fill in real values locally. Do NOT commit .env.

# Optional Groq hybrid layer. Leave disabled for deterministic offline judging.
ENABLE_GROQ=false
GROQ_API_KEY=
MODEL_NAME=llama-3.3-70b-versatile

# Server port
PORT=8000

# Timeouts
REQUEST_TIMEOUT_SECONDS=30
HEALTH_TIMEOUT_SECONDS=60